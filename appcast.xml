            <sparkle:shortVersionString>1.3.1</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>14.0</sparkle:minimumSystemVersion>
            <description><![CDATA[
                <h2>What's New in Plotted 1.3.1</h2>
                <ul>
                    <li>Trackers: fixed overlapping month labels on the mini heatmap (no more "MarApr").</li>
                    <li>System: correct pluralization in the Capacity card ("1 goal" / "1 habit" instead of "1 goals" / "1 habits").</li>
                    <li>Insights: improved contrast on locked achievement names and descriptions for readability.</li>
                </ul>
            ]]></description>
